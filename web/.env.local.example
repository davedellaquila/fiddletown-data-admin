# Copy to web/.env.local and fill in values (never commit .env.local)

VITE_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional — skip magic link in dev (see docs/DEVELOPMENT_AUTH.md)
VITE_DEV_AUTH_EMAIL=dev@yourdomain.com
VITE_DEV_AUTH_PASSWORD=your-dev-password
